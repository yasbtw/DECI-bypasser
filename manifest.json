{
  "name": "DECI Desktop Bypasser",
  "version": "1.0",
  "description": "Bypasses the DECI desktop check",
  "permissions": ["scripting"],
  "manifest_version": 3,
"action": {
    "default_popup": "author.html"
  },
  "content_scripts": [
    {
      "matches": ["https://deci.eyouthbusiness.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}